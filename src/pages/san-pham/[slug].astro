---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, getProduct } from '../../data/products';
import { CheckCircle2, MapPin, ShieldCheck, Smartphone, Wrench } from 'lucide-astro';
export function getStaticPaths(){return products.map(product=>({params:{slug:product.slug}}));}
const product=getProduct(Astro.params.slug!)!;
const related=products.filter(item=>item.slug!==product.slug).slice(0,3);
---
<BaseLayout title={`${product.name} — ${product.subtitle} | An Tâm GPS`} description={product.description}><Header/><main>
<section class="product-hero"><div class="container-site product-hero-grid">
  <div><span class="eyebrow">{product.category} · {product.badge}</span><h1>{product.name}</h1><h2>{product.subtitle}</h2><p class="lead">{product.description}</p>
  <div class="highlight-list">{product.highlights.map(item=><div class="highlight"><CheckCircle2 size={20} color="#16852b"/><span>{item}</span></div>)}</div>
  <div class="hero-actions"><a class="btn btn-green" href="/#lien-he">Liên hệ tư vấn</a><a class="btn btn-ghost" href="#thong-so">Xem thông số</a></div></div>
  <div class="product-showcase"><img src={product.image} alt={`${product.name} - ${product.subtitle}`}/></div>
</div></section>
<section class="section"><div class="container-site"><div style="max-width:760px"><span class="eyebrow">TÍNH NĂNG NỔI BẬT</span><h2 class="h2">Quản lý phương tiện dễ dàng và an toàn hơn.</h2></div><div class="feature-grid">{product.features.map((feature,index)=>{const icons=[MapPin,ShieldCheck,Smartphone,Wrench];const Icon=icons[index%icons.length];return <article class="card feature-card"><div class="icon-box"><Icon size={27}/></div><h3>{feature.title}</h3><p>{feature.description}</p></article>})}</div></div></section>
<section class="section section-soft" id="thong-so"><div class="container-site app-grid"><div><span class="eyebrow">THÔNG SỐ KỸ THUẬT</span><h2 class="h2">Thông tin rõ ràng, dễ đối chiếu.</h2><p class="lead">Các thông số chính được chuẩn hóa từ tài liệu sản phẩm để khách hàng dễ lựa chọn và kỹ thuật viên dễ kiểm tra.</p></div><div class="spec-grid">{product.specs.map(spec=><div class="spec-row"><span>{spec.label}</span><b>{spec.value}</b></div>)}</div></div></section>
{product.gallery.length>0 && <section class="section"><div class="container-site"><span class="eyebrow">HÌNH ẢNH & TÀI LIỆU</span><h2 class="h2">Thông tin sản phẩm chi tiết.</h2><div class="gallery-grid">{product.gallery.map(image=><img src={image} alt={`Tài liệu ${product.name}`} loading="lazy"/>)}</div></div></section>}
<section class="section section-soft"><div class="container-site"><div style="max-width:760px"><span class="eyebrow">ỨNG DỤNG THỰC TẾ</span><h2 class="h2">Phù hợp với nhiều loại phương tiện.</h2></div><div class="feature-grid">{product.applications.map(item=><article class="card feature-card"><div class="icon-box"><CheckCircle2 size={26}/></div><h3>{item}</h3><p>Theo dõi và quản lý trực tiếp trên ứng dụng GPS-ANTAM.</p></article>)}</div></div></section>
<section class="section"><div class="container-site"><div class="section-head"><div><span class="eyebrow">SẢN PHẨM LIÊN QUAN</span><h2 class="h2" style="margin-bottom:0">Tham khảo thêm thiết bị khác.</h2></div><a class="text-link" href="/san-pham/">Xem tất cả →</a></div><div class="product-grid related-grid">{related.map(item=><ProductCard product={item}/>)}</div></div></section>
</main><Footer/></BaseLayout>
