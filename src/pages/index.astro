---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products';
import { MapPin, BellRing, Route, ShieldCheck, Smartphone, Headphones, CheckCircle2, RadioTower, BadgeCheck, ExternalLink } from 'lucide-astro';
---
<BaseLayout title="An Tâm GPS — Định vị chính xác, an tâm mọi hành trình" description="Thiết bị định vị GPS 4G, ứng dụng GPS-ANTAM, SIM data và hỗ trợ kỹ thuật toàn diện.">
<Header />
<main>
  <section class="hero">
    <div class="container-site hero-grid">
      <div class="hero-intro">
        <span class="hero-chip">GIẢI PHÁP ĐỊNH VỊ GPS 4G THÔNG MINH</span>
        <h1>
  <span class="hero-line hero-green">
    Biết xe đang ở đâu.
  </span>

  <span class="hero-line hero-white">
    An tâm mọi hành trình.
  </span>
</h1>
        <p class="hero-copy">Theo dõi phương tiện theo thời gian thực, nhận cảnh báo thông minh và quản lý nhiều thiết bị trên ứng dụng GPS-ANTAM.</p>
      </div>

      <div class="hero-visual">
        <div class="hero-glow"></div>
        <img class="hero-composition" src="/assets/app/hero-phone-h29p.png" alt="Điện thoại hiển thị ứng dụng GPS-ANTAM và thiết bị H29P" />
      </div>

      <div class="hero-bottom">
        <div class="hero-features">
          <div><b>Định vị chính xác</b><span>Sai số ≤ 5 mét</span></div>
          <div><b>Kết nối 4G ổn định</b><span>Tốc độ cao</span></div>
          <div><b>Bảo vệ 24/7</b><span>Cảnh báo tức thời</span></div>
          <div><b>Pin dự phòng</b><span>Hoạt động liên tục</span></div>
        </div>
        <div class="hero-actions"><a class="btn btn-green" href="#san-pham">Khám phá sản phẩm</a><a class="btn hero-secondary" href="#ung-dung">Xem ứng dụng</a></div>
      </div>
    </div>
  </section>

  <section class="gift-strip" aria-label="Ưu đãi khi mua thiết bị">
    <div class="container-site gift-grid">
      <div class="gift-copy"><span>Quà tặng khi mua thiết bị</span><h2>SIM 4G & ứng dụng miễn phí 12 tháng</h2><p>Kích hoạt sẵn — Sử dụng ngay — Không phát sinh chi phí trong năm đầu.</p></div>
      <div class="gift-qr"><img src="/assets/app/qr-app.png" alt="QR tải ứng dụng GPS-ANTAM"/><div><b>Quét mã tải ứng dụng</b><a href="https://www.iopgps.com/" target="_blank" rel="noopener">Mở phiên bản Web <ExternalLink size={15}/></a></div></div>
      <div class="gift-list"><span><CheckCircle2 size={18}/>Miễn phí SIM Data 12 tháng đầu</span><span><CheckCircle2 size={18}/>Miễn phí sử dụng ứng dụng 12 tháng đầu</span><span><CheckCircle2 size={18}/>Kích hoạt sẵn trước khi giao</span><span><CheckCircle2 size={18}/>Hỗ trợ cài đặt và hướng dẫn sử dụng</span></div>
    </div>
  </section>

  <section class="section" id="giai-phap"><div class="container-site">
    <div class="section-intro"><span class="eyebrow">VÌ SAO CẦN GPS?</span><h2 class="h2">Bảo vệ phương tiện bằng thông tin chính xác.</h2><p class="lead">Không chỉ biết xe đang ở đâu, hệ thống còn giúp xem lại hành trình, nhận cảnh báo và quản lý nhiều phương tiện trong cùng một tài khoản.</p></div>
    <div class="feature-grid">
      {[[MapPin,'Theo dõi trực tuyến','Cập nhật vị trí phương tiện theo thời gian thực trên điện thoại.'],[Route,'Lịch sử hành trình','Xem lại quãng đường, thời gian và tốc độ đã di chuyển.'],[BellRing,'Cảnh báo thông minh','Nhận thông báo rung, di chuyển, mất nguồn hoặc vượt tốc.'],[ShieldCheck,'Bảo vệ 24/7','Tăng khả năng kiểm soát và xử lý nhanh khi có bất thường.']].map(([Icon,title,desc])=><article class="card feature-card"><div class="icon-box"><Icon size={27}/></div><h3>{title}</h3><p>{desc}</p></article>)}
    </div>
  </div></section>

  <section class="section section-soft" id="san-pham"><div class="container-site">
    <div class="section-intro product-intro"><span class="eyebrow eyebrow-green">SẢN PHẨM NỔI BẬT</span><h2 class="h2 section-title-no-margin">Thiết bị định vị thông minh</h2></div>
    <div class="product-grid">{products.map(product=><ProductCard product={product}/>)}</div>
  </div></section>

  <section class="section" id="ung-dung"><div class="container-site app-grid">
    <div class="app-image-wrap"><img src="/assets/app/app-phone.png" alt="Ứng dụng GPS-ANTAM hiển thị trên điện thoại" class="app-image"/></div>
    <div><span class="eyebrow">ỨNG DỤNG GPS-ANTAM</span><h2 class="h2">Quản lý mọi lúc, trên mọi thiết bị.</h2><p class="lead">Theo dõi vị trí, xem lịch sử, nhận cảnh báo và quản lý nhiều phương tiện trong cùng một tài khoản đơn giản, trực quan.</p>
      <div class="check-list">{['Miễn phí SIM Data trong 12 tháng đầu','Miễn phí sử dụng ứng dụng trong 12 tháng đầu','Kích hoạt sẵn trước khi giao','Hỗ trợ cài đặt và hướng dẫn sử dụng'].map(item=><div class="check-row"><CheckCircle2 size={22}/><span>{item}</span></div>)}</div>
      <div class="app-download-row"><img src="/assets/app/qr-app.png" alt="QR tải ứng dụng"/><div><b>Quét mã để tải ứng dụng</b><span>Dùng camera điện thoại để quét mã QR.</span><a class="web-app-link" href="https://www.iopgps.com/" target="_blank" rel="noopener">Mở ứng dụng trên Web <ExternalLink size={16}/></a></div></div>
      <div class="app-actions"><a class="btn btn-primary" href="#lien-he">Nhận tư vấn</a><a class="btn btn-ghost" href="https://www.iopgps.com/" target="_blank" rel="noopener">Sử dụng trên Web</a></div>
    </div>
  </div></section>

  <section class="section section-soft" id="ho-tro"><div class="container-site">
    <div class="section-intro"><span class="eyebrow">HỆ SINH THÁI AN TÂM GPS</span><h2 class="h2">Thiết bị, SIM, ứng dụng và hỗ trợ trong một giải pháp.</h2><p class="lead">Khách hàng không phải tự tìm từng dịch vụ rời rạc. Mọi thành phần được chuẩn bị đồng bộ để thiết bị hoạt động ổn định ngay khi nhận.</p></div>
    <div class="ecosystem-grid">{[[RadioTower,'SIM 4G tặng kèm','Kết nối dữ liệu được chuẩn bị và kích hoạt sẵn.'],[Smartphone,'Ứng dụng GPS-ANTAM','Giao diện trực quan trên điện thoại và nền tảng Web.'],[BadgeCheck,'Bảo hành 12 tháng','Chính sách rõ ràng, hỗ trợ nhanh khi thiết bị có lỗi.'],[Headphones,'Hỗ trợ kỹ thuật','Tư vấn lắp đặt, cài ứng dụng và sử dụng tận tâm.']].map(([Icon,title,desc])=><article class="card ecosystem-card"><div class="icon-box"><Icon size={27}/></div><h3>{title}</h3><p>{desc}</p></article>)}</div>
    <div class="cta-band"><div><h3>Cần chọn thiết bị phù hợp cho phương tiện?</h3><p>Đội ngũ An Tâm GPS tư vấn đúng nhu cầu, đúng loại xe và đúng phương án lắp đặt.</p></div><a class="btn btn-green" href="tel:0866306478">Gọi 0866 306 478</a></div>
  </div></section>
</main>
<Footer />
</BaseLayout>
